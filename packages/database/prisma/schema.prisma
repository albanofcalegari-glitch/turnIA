generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (negocio)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  type      String   // peluqueria | barberia | spa | estetica | custom
  timezone  String   @default("America/Argentina/Buenos_Aires")
  logoUrl   String?
  phone     String?
  address   String?
  settings  Json     @default("{}")
  isActive             Boolean   @default(true)
  plan                 String    @default("trial") // trial | standard | free (legacy)
  membershipExpiresAt  DateTime? // null = sin vencimiento (cuentas internas). Durante trial: now + 45d. Luego se extiende +30d por cada pago MP aprobado.
  /// Stage 1 (branches): drives whether the UI exposes branch selection.
  /// Single-branch tenants keep this false and never see branch UI; the
  /// default branch still exists in the DB to satisfy NOT NULL FKs.
  hasMultipleBranches  Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users              TenantUser[]
  branches           Branch[]
  services           Service[]
  categories         ServiceCategory[]
  professionals      Professional[]
  appointments       Appointment[]
  scheduleRules      ScheduleRule?
  resources          Resource[]
  auditLogs          AuditLog[]
  clients            Client[]
  workSchedules      WorkSchedule[]
  scheduleExceptions ScheduleException[]
  subscription       Subscription?
  payments           Payment[]
  loyaltyProgram     LoyaltyProgram?
  loyaltyCards       LoyaltyCard[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// SUBSCRIPTION (Mercado Pago preapproval) — one row per tenant.
//
// Mirrors the MP preapproval resource. We store `mpPreapprovalId` so we can
// reconcile webhook events (MP sends the preapproval id, not our tenantId).
// `status` tracks the MP lifecycle: pending (awaiting first payment) →
// authorized (active, paying) → paused / cancelled (terminal).
// ─────────────────────────────────────────────────────────────────────────────
model Subscription {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mpPreapprovalId   String   @unique
  mpPlanId          String?  // preapproval_plan_id if created from a plan
  status            String   // pending | authorized | paused | cancelled
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("ARS")
  frequency         Int      @default(1)      // 1
  frequencyType     String   @default("months") // months | days
  payerEmail        String
  initPoint         String?  // URL MP returned to start the checkout
  nextPaymentDate   DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  payments Payment[]

  @@index([status])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT — immutable log of every MP payment event for audit + admin metrics.
//
// We persist the raw webhook payload (rawPayload) on purpose: MP changes
// response shapes without notice, and we don't want to lose data if a column
// we care about moves. The indexed columns are the ones the superadmin view
// filters/aggregates on.
// ─────────────────────────────────────────────────────────────────────────────
model Payment {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionId  String?
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  mpPaymentId     String   @unique
  status          String   // approved | rejected | refunded | pending | cancelled
  statusDetail    String?
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("ARS")
  paymentMethod   String?  // visa | master | amex | account_money | etc
  paymentType     String?  // credit_card | debit_card | account_money
  paidAt          DateTime?
  rawPayload      Json
  createdAt       DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([status])
  @@index([paidAt])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCH (sucursal)
//
// Stage 1: every tenant has at least one Branch (the default one created at
// onboarding). Single-location tenants leave Tenant.hasMultipleBranches=false
// and the UI hides every branch concept; the row still exists so that
// branchId FKs on WorkSchedule / Appointment / Resource are well-defined.
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String   // unique per tenant — used in admin UI and (future) URLs
  address   String?
  phone     String?
  timezone  String?  // null → inherits Tenant.timezone
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false) // exactly one default per tenant (enforced at app layer)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionals       ProfessionalBranch[]
  serviceAvailability ServiceBranch[]
  workSchedules       WorkSchedule[]
  appointments        Appointment[]
  resources           Resource[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("branches")
}

// Join: which branches a professional works at. M:N because the same
// physical professional may rotate across multiple sucursales.
model ProfessionalBranch {
  professionalId String
  branchId       String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([professionalId, branchId])
  @@index([branchId])
  @@map("professional_branches")
}

// Join: opt-in restriction list. NO rows for a service ⇒ available everywhere.
// This way single-branch tenants and existing services need zero rows here.
model ServiceBranch {
  serviceId String
  branchId  String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([serviceId, branchId])
  @@index([branchId])
  @@map("service_branches")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER (global — puede pertenecer a múltiples tenants con distintos roles)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  isSuperAdmin Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Email verification — opcional, no bloquea operación. Si emailVerifiedAt
  // está null, la UI muestra un banner pidiendo confirmar.
  emailVerifiedAt          DateTime?
  emailVerificationToken   String?   @unique

  // Password reset — token de un solo uso con expiración corta.
  passwordResetToken       String?   @unique
  passwordResetExpiresAt   DateTime?

  tenants              TenantUser[]
  professional         Professional?
  clients              Client[]              // un usuario puede ser cliente en múltiples tenants
  assignedResources    AppointmentResource[] // recursos que asignó

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT USER (relación usuario ↔ tenant con rol)
// ─────────────────────────────────────────────────────────────────────────────

model TenantUser {
  id       String     @id @default(cuid())
  userId   String
  tenantId String
  role     TenantRole @default(CLIENT)
  joinedAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_users")
}

enum TenantRole {
  ADMIN
  PROFESSIONAL // → se renombrará a STAFF en Etapa 2
  CLIENT       // → se eliminará en Etapa 3 (reemplazado por tabla clients)
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE CATEGORY
// ─────────────────────────────────────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("service_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id               String   @id @default(cuid())
  tenantId         String
  categoryId       String?
  name             String
  description      String?
  durationMinutes  Int
  bufferBefore     Int      @default(0)
  bufferAfter      Int      @default(0)
  price            Decimal  @db.Decimal(10, 2)
  currency         String   @default("ARS")
  color            String?
  isActive         Boolean  @default(true)
  isPublic         Boolean  @default(true)
  requiresResource Boolean  @default(false)
  maxParallelBookings Int   @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         ServiceCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  professionals    ProfessionalService[]
  appointmentItems AppointmentItem[]
  serviceResources ServiceResource[]
  branches         ServiceBranch[]

  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROFESSIONAL
// ─────────────────────────────────────────────────────────────────────────────

model Professional {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String?  @unique
  displayName          String
  bio                  String?
  avatarUrl            String?
  color                String?
  isActive             Boolean  @default(true)
  acceptsOnlineBooking Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  services     ProfessionalService[]
  schedules    WorkSchedule[]
  exceptions   ScheduleException[]
  appointments Appointment[]
  branches     ProfessionalBranch[]

  @@map("professionals")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROFESSIONAL SERVICE (qué servicios ofrece cada profesional)
// ─────────────────────────────────────────────────────────────────────────────

model ProfessionalService {
  professionalId   String
  serviceId        String
  overridePrice    Decimal? @db.Decimal(10, 2)
  overrideDuration Int?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@map("professional_services")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK SCHEDULE (horarios semanales recurrentes del profesional)
//
// Stage 1: se agrega tenantId para queries eficientes por tenant,
//          soporte RLS, e índice de slot-calculation.
// ─────────────────────────────────────────────────────────────────────────────

model WorkSchedule {
  id             String   @id @default(cuid())
  tenantId       String   // agregado en Stage 1
  /// Stage 1 (branches) — phase 2: NOT NULL + uniqueness moved to
  /// (branchId, professionalId, dayOfWeek) so the same pro can have
  /// different hours per sucursal on the same weekday.
  branchId       String
  professionalId String
  dayOfWeek      Int      // 0=Dom, 1=Lun, 2=Mar, 3=Mie, 4=Jue, 5=Vie, 6=Sab
  startTime      String   // "09:00" — migrar a @db.Time en Etapa 2 previa validación
  endTime        String   // "18:00"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) // agregado en Stage 1
  updatedAt      DateTime @updatedAt      // agregado en Stage 1

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // A pro can have one weekly entry per (branch, day). Phase 2 dropped the
  // tenant-scoped unique key in favour of this branch-scoped one.
  @@unique([branchId, professionalId, dayOfWeek])
  @@index([tenantId, professionalId])
  @@index([branchId])
  @@map("work_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHEDULE EXCEPTION (bloqueos, vacaciones, feriados)
//
// Stage 1: se agrega tenantId para queries eficientes y futura RLS.
// ─────────────────────────────────────────────────────────────────────────────

model ScheduleException {
  id             String        @id @default(cuid())
  tenantId       String        // agregado en Stage 1
  professionalId String
  date           DateTime      @db.Date
  type           ExceptionType
  startTime      String?       // null = todo el día bloqueado
  endTime        String?
  reason         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt // agregado en Stage 1

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([tenantId, professionalId, date])
  @@map("schedule_exceptions")
}

enum ExceptionType {
  BLOCK
  VACATION
  HOLIDAY
  CUSTOM_HOURS
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT (turno)
// ─────────────────────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(cuid())
  tenantId           String
  /// Stage 1 (branches) — phase 2: NOT NULL. Every appointment is anchored
  /// to exactly one sucursal; the slot engine and create/reschedule writes
  /// guarantee a value at insert time.
  branchId           String
  clientId           String?           // FK → Client
  professionalId     String
  status             AppointmentStatus @default(PENDING)
  startAt            DateTime
  endAt              DateTime
  totalMinutes       Int
  totalPrice         Decimal           @db.Decimal(10, 2)
  currency           String            @default("ARS")
  notes              String?           // notas del cliente
  internalNotes      String?           // notas internas del negocio
  // datos de invitado
  guestName          String?
  guestEmail         String?
  guestPhone         String?
  // auditoría de cancelación / reprogramación
  cancelledAt        DateTime?
  cancelledBy        String?           // userId quien canceló
  cancellationReason String?
  rescheduledFromId  String?           // id del appointment original
  confirmedAt        DateTime?
  completedAt        DateTime?
  // ── Stage 1 ──────────────────────────────────────────────────────────────
  version            Int               @default(1) // optimistic locking ORM
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  client               Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  professional         Professional            @relation(fields: [professionalId], references: [id])
  items                AppointmentItem[]
  appointmentResources AppointmentResource[]   // agregado en Stage 1
  loyaltyStamps        LoyaltyStamp[]
  loyaltyRedemptions   LoyaltyRedemption[]
  attachments          AppointmentAttachment[]

  @@index([tenantId, startAt])
  @@index([tenantId, status, startAt]) // agregado en Stage 1 — dashboard queries
  @@index([professionalId, startAt])
  @@index([branchId, startAt])         // agregado en Stage 1 (branches) — agenda por sede
  @@index([clientId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT ITEM (servicios dentro de un turno — soporta múltiples)
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentItem {
  id              String  @id @default(cuid())
  appointmentId   String
  serviceId       String
  serviceName     String  // snapshot en el momento de la reserva
  durationMinutes Int
  price           Decimal @db.Decimal(10, 2) // → renombrar a unitPrice en Etapa 2
  order           Int     @default(0)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@index([appointmentId])
  @@map("appointment_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT ATTACHMENT (imágenes u otros archivos cargados contra un turno:
// comprobantes de pago, fotos "antes/después", referencias, etc.)
//
// Stage 1 (minimal): se guarda el archivo en disco — la app expone el path
// relativo vía `url`. Una futura migración puede mover a S3 / CDN.
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentAttachment {
  id            String   @id @default(cuid())
  appointmentId String
  /// URL relativa pública (ej: /uploads/appointments/{apptId}/{fileId}.jpg)
  url           String
  /// Nombre original del archivo tal como lo subió el usuario.
  filename      String
  mimeType      String
  sizeBytes     Int
  /// userId de quien subió (nullable: en el futuro podríamos permitir guest
  /// uploads desde la página pública, por eso no es NOT NULL).
  uploadedById  String?
  createdAt     DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_attachments")
}

// ─────────────────────────────────────────────────────────────────────────────
// RESOURCE (recursos físicos: cabinas, sillas, salas, equipos)
//
// Stage 1: se agregan description, capacity, createdAt, updatedAt
//          y la relación appointmentResources.
// ─────────────────────────────────────────────────────────────────────────────

model Resource {
  id          String   @id @default(cuid())
  tenantId    String
  /// Stage 1 (branches) — phase 2: NOT NULL. Resources (cabinas, sillas,
  /// salas, equipos) are physical assets and always live at exactly one
  /// sucursal.
  branchId    String
  name        String
  type        String   // → migrar a resourceTypeId FK en Etapa 2
  description String?  // agregado en Stage 1
  capacity    Int      @default(1) // agregado en Stage 1
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) // agregado en Stage 1
  updatedAt   DateTime @updatedAt      // agregado en Stage 1

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  services             ServiceResource[]
  appointmentResources AppointmentResource[] // agregado en Stage 1

  @@index([branchId])
  @@map("resources")
}

model ServiceResource {
  serviceId  String
  resourceId String

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([serviceId, resourceId])
  @@map("service_resources")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENT (CRM por tenant)
//
// Stage 1: tabla creada. appointments.clientId todavía apunta a User.
//          La migración de appointments.clientId → Client ocurre en Etapa 2.
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  // null = guest que no tiene cuenta en el sistema
  firstName String
  lastName  String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  loyaltyCard  LoyaltyCard?

  // PostgreSQL trata NULL como distinto de NULL en constraints UNIQUE,
  // por lo tanto múltiples guests (userId=NULL) son permitidos en el mismo tenant.
  // La constraint sólo previene que el mismo usuario registrado aparezca dos veces.
  @@unique([tenantId, userId])
  @@index([tenantId, email])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT RESOURCE (recursos físicos asignados a un turno)
//
// Stage 1: tabla nueva. Habilita tracking de qué recurso fue usado
//          por qué turno, y permite detectar doble reserva de recursos.
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentResource {
  id               String   @id @default(cuid())
  appointmentId    String
  resourceId       String
  resourceName     String   // snapshot del nombre al momento de la asignación
  assignedAt       DateTime @default(now())
  assignedByUserId String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])
  assignedBy  User?       @relation(fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([appointmentId, resourceId])
  @@index([resourceId, assignedAt]) // para verificar disponibilidad de recurso
  @@map("appointment_resources")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHEDULE RULE (configuración global del negocio)
// ─────────────────────────────────────────────────────────────────────────────

model ScheduleRule {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  slotDurationMinutes Int     @default(15)
  bookingWindowDays   Int     @default(30)
  minAdvanceMinutes   Int     @default(60)
  cancelHoursMin      Int     @default(24)
  rescheduleHoursMin  Int     @default(24)
  allowGuestBooking   Boolean @default(true)
  requireConfirmation Boolean @default(false)
  autoConfirm         Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("schedule_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String
  payload   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOYALTY PROGRAM (configuración del "club de fidelidad" por tenant)
//
// Una row por tenant. Cuando isActive=true, cada appointment COMPLETED para un
// cliente registrado genera un stamp en su LoyaltyCard. Al alcanzar
// stampsRequired, se habilita un reward que el negocio marca como canjeado
// cuando el cliente lo usa.
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyProgram {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  isActive        Boolean  @default(true)
  showOnBooking   Boolean  @default(false)
  rewardMode      LoyaltyRewardMode @default(CUMULATIVE)
  // --- campos legacy (single-reward) — se migran a LoyaltyReward ---
  stampsRequired  Int      @default(5)
  rewardType      LoyaltyRewardType @default(FREE_SERVICE)
  rewardValue     Decimal? @db.Decimal(10, 2)
  rewardLabel     String
  // null = aplica a todos los servicios; array de serviceId = restringido
  eligibleServiceIds Json?
  // Branding de la tarjeta
  cardTitle       String   @default("Club de Fidelidad")
  cardSubtitle    String?  // p.ej. "Cada 5 cortes, uno gratis"
  cardColor       String   @default("#0f172a") // hex principal
  cardAccentColor String?  // hex secundario para patrón
  cardBgImageUrl  String?  // opcional: imagen de fondo (ej: foto del local)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cards   LoyaltyCard[]
  rewards LoyaltyReward[]

  @@map("loyalty_programs")
}

enum LoyaltyRewardMode {
  CUMULATIVE  // stamps acumulan hacia milestones: 5→reward1, 10→reward2, reset
  INDEPENDENT // cada reward tiene su propio ciclo (futuro)
}

enum LoyaltyRewardType {
  FREE_SERVICE      // rewardValue ignorado
  DISCOUNT_PERCENT  // rewardValue = 0..100
  DISCOUNT_AMOUNT   // rewardValue = monto en currency del tenant
}

// ─────────────────────────────────────────────────────────────────────────────
// LOYALTY REWARD (milestone de un programa — hasta 4 por programa)
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyReward {
  id             String            @id @default(cuid())
  programId      String
  position       Int               // 1-4, orden visual y de evaluación
  stampsRequired Int               // CUMULATIVE: threshold acumulado (ej: 5, 10)
  rewardType     LoyaltyRewardType
  rewardValue    Decimal?          @db.Decimal(10, 2)
  rewardLabel    String
  createdAt      DateTime          @default(now())

  program LoyaltyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, position])
  @@map("loyalty_rewards")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOYALTY CARD (tarjeta de un cliente en el programa del tenant)
//
// Una por cliente. Campos denormalizados (stampsCount, rewardsAvailable) se
// mantienen al día desde el servicio; la fuente de verdad auditable son las
// filas en LoyaltyStamp / LoyaltyRedemption.
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyCard {
  id                 String   @id @default(cuid())
  tenantId           String
  programId          String
  clientId           String   @unique
  stampsCount        Int      @default(0) // stamps en el ciclo actual
  totalStampsEarned  Int      @default(0) // lifetime — para stats
  rewardsAvailable   Int      @default(0) // rewards ganados y no canjeados (denorm)
  rewardsRedeemed    Int      @default(0) // lifetime canjeados
  availableRewardIds Json     @default("[]") // string[] de LoyaltyReward.id pendientes de canjear
  lastStampAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program     LoyaltyProgram      @relation(fields: [programId], references: [id], onDelete: Cascade)
  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  stamps      LoyaltyStamp[]
  redemptions LoyaltyRedemption[]

  @@index([tenantId, clientId])
  @@map("loyalty_cards")
}

// ─────────────────────────────────────────────────────────────────────────────
// LOYALTY STAMP (log auditable de cada sello emitido)
//
// Una row por stamp. Si un appointment COMPLETED se cancela o revierte,
// insertamos una fila con delta=-1 y reason=REVERSAL en vez de borrar — así
// preservamos el historial.
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyStamp {
  id            String   @id @default(cuid())
  cardId        String
  appointmentId String?  // null si fue MANUAL
  delta         Int      @default(1) // +1 normal, -1 en REVERSAL
  reason        LoyaltyStampReason @default(COMPLETED)
  note          String?
  createdAt     DateTime @default(now())

  card        LoyaltyCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@unique([cardId, appointmentId, reason]) // evita duplicar stamps para el mismo appointment
  @@index([cardId, createdAt])
  @@map("loyalty_stamps")
}

enum LoyaltyStampReason {
  COMPLETED  // turno marcado como completado
  MANUAL     // el negocio agregó un stamp manualmente
  REVERSAL   // se revirtió un stamp previo (appointment cancelado)
}

// ─────────────────────────────────────────────────────────────────────────────
// LOYALTY REDEMPTION (uso de un reward por parte del cliente)
//
// Una row cada vez que se canjea un reward. Guardamos snapshot del rewardType
// y rewardValue para que un cambio futuro en la config del programa no
// reinterprete rewards ya canjeados.
// ─────────────────────────────────────────────────────────────────────────────

model LoyaltyRedemption {
  id              String   @id @default(cuid())
  cardId          String
  appointmentId   String?  // turno donde se aplicó el reward (si aplica)
  rewardType      LoyaltyRewardType
  rewardValue     Decimal? @db.Decimal(10, 2)
  rewardLabel     String   // snapshot del label al momento del canje
  redeemedAt      DateTime @default(now())
  redeemedByUserId String? // staff que registró el canje

  card        LoyaltyCard  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([cardId, redeemedAt])
  @@map("loyalty_redemptions")
}
