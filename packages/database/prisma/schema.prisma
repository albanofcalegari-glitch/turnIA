generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (negocio)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  type      String   // peluqueria | barberia | spa | estetica | custom
  timezone  String   @default("America/Argentina/Buenos_Aires")
  logoUrl   String?
  phone     String?
  address   String?
  settings  Json     @default("{}")
  isActive             Boolean   @default(true)
  plan                 String    @default("free") // free | starter | pro
  membershipExpiresAt  DateTime? // null = sin vencimiento (plan free o lifetime)
  /// Stage 1 (branches): drives whether the UI exposes branch selection.
  /// Single-branch tenants keep this false and never see branch UI; the
  /// default branch still exists in the DB to satisfy NOT NULL FKs.
  hasMultipleBranches  Boolean   @default(false)
  /// Phase 1 (work-orders): default length of a workday in hours.
  /// Used when a service's durationUnit=WORKDAYS and its own workdayHours is null.
  defaultWorkdayHours  Decimal   @default(8.0) @db.Decimal(4, 1)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users              TenantUser[]
  branches           Branch[]
  services           Service[]
  categories         ServiceCategory[]
  professionals      Professional[]
  appointments       Appointment[]
  scheduleRules      ScheduleRule?
  resources          Resource[]
  auditLogs          AuditLog[]
  clients            Client[]
  workSchedules      WorkSchedule[]
  scheduleExceptions ScheduleException[]
  workOrders         WorkOrder[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// BRANCH (sucursal)
//
// Stage 1: every tenant has at least one Branch (the default one created at
// onboarding). Single-location tenants leave Tenant.hasMultipleBranches=false
// and the UI hides every branch concept; the row still exists so that
// branchId FKs on WorkSchedule / Appointment / Resource are well-defined.
// ─────────────────────────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String   // unique per tenant — used in admin UI and (future) URLs
  address   String?
  phone     String?
  timezone  String?  // null → inherits Tenant.timezone
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false) // exactly one default per tenant (enforced at app layer)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professionals       ProfessionalBranch[]
  serviceAvailability ServiceBranch[]
  workSchedules       WorkSchedule[]
  appointments        Appointment[]
  resources           Resource[]
  workOrders          WorkOrder[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
  @@map("branches")
}

// Join: which branches a professional works at. M:N because the same
// physical professional may rotate across multiple sucursales.
model ProfessionalBranch {
  professionalId String
  branchId       String
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([professionalId, branchId])
  @@index([branchId])
  @@map("professional_branches")
}

// Join: opt-in restriction list. NO rows for a service ⇒ available everywhere.
// This way single-branch tenants and existing services need zero rows here.
model ServiceBranch {
  serviceId String
  branchId  String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([serviceId, branchId])
  @@index([branchId])
  @@map("service_branches")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER (global — puede pertenecer a múltiples tenants con distintos roles)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  isSuperAdmin Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenants              TenantUser[]
  professional         Professional?
  clients              Client[]              // un usuario puede ser cliente en múltiples tenants
  assignedResources    AppointmentResource[] // recursos que asignó

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT USER (relación usuario ↔ tenant con rol)
// ─────────────────────────────────────────────────────────────────────────────

model TenantUser {
  id       String     @id @default(cuid())
  userId   String
  tenantId String
  role     TenantRole @default(CLIENT)
  joinedAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("tenant_users")
}

enum TenantRole {
  ADMIN
  PROFESSIONAL // → se renombrará a STAFF en Etapa 2
  CLIENT       // → se eliminará en Etapa 3 (reemplazado por tabla clients)
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE CATEGORY
// ─────────────────────────────────────────────────────────────────────────────

model ServiceCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  color       String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("service_categories")
}

// ─────────────────────────────────────────────────────────────────────────────
// SERVICE
// ─────────────────────────────────────────────────────────────────────────────

model Service {
  id               String   @id @default(cuid())
  tenantId         String
  categoryId       String?
  name             String
  description      String?
  durationMinutes  Int
  bufferBefore     Int      @default(0)
  bufferAfter      Int      @default(0)
  price            Decimal  @db.Decimal(10, 2)
  currency         String   @default("ARS")
  color            String?
  isActive         Boolean  @default(true)
  isPublic         Boolean  @default(true)
  requiresResource Boolean  @default(false)
  maxParallelBookings Int   @default(1)
  // ── Phase 1 (work-orders): operational profile ─────────────────────────
  /// Duration unit for scheduling. MINUTES keeps legacy behaviour.
  durationUnit        DurationUnit @default(MINUTES)
  /// Numeric duration expressed in `durationUnit`. 0 = use legacy durationMinutes.
  durationValue       Decimal      @default(0) @db.Decimal(6, 1)
  /// Hours per workday for this service. null = use tenant.defaultWorkdayHours.
  workdayHours        Decimal?     @db.Decimal(4, 1)
  /// Minimum professionals required simultaneously for this service.
  minProfessionals    Int          @default(1)
  /// Maximum professionals allowed simultaneously.
  maxProfessionals    Int          @default(1)
  /// Whether this service can span multiple working days.
  allowsMultiDay      Boolean      @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category         ServiceCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  professionals    ProfessionalService[]
  appointmentItems AppointmentItem[]
  serviceResources ServiceResource[]
  branches         ServiceBranch[]
  workOrders       WorkOrder[]

  @@map("services")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROFESSIONAL
// ─────────────────────────────────────────────────────────────────────────────

model Professional {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String?  @unique
  displayName          String
  bio                  String?
  avatarUrl            String?
  color                String?
  isActive             Boolean  @default(true)
  acceptsOnlineBooking Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  services         ProfessionalService[]
  schedules        WorkSchedule[]
  exceptions       ScheduleException[]
  appointments     Appointment[]
  branches         ProfessionalBranch[]
  staffAssignments StaffAssignment[]

  @@map("professionals")
}

// ─────────────────────────────────────────────────────────────────────────────
// PROFESSIONAL SERVICE (qué servicios ofrece cada profesional)
// ─────────────────────────────────────────────────────────────────────────────

model ProfessionalService {
  professionalId   String
  serviceId        String
  overridePrice    Decimal? @db.Decimal(10, 2)
  overrideDuration Int?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([professionalId, serviceId])
  @@map("professional_services")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK SCHEDULE (horarios semanales recurrentes del profesional)
//
// Stage 1: se agrega tenantId para queries eficientes por tenant,
//          soporte RLS, e índice de slot-calculation.
// ─────────────────────────────────────────────────────────────────────────────

model WorkSchedule {
  id             String   @id @default(cuid())
  tenantId       String   // agregado en Stage 1
  /// Stage 1 (branches) — phase 2: NOT NULL + uniqueness moved to
  /// (branchId, professionalId, dayOfWeek) so the same pro can have
  /// different hours per sucursal on the same weekday.
  branchId       String
  professionalId String
  dayOfWeek      Int      // 0=Dom, 1=Lun, 2=Mar, 3=Mie, 4=Jue, 5=Vie, 6=Sab
  startTime      String   // "09:00" — migrar a @db.Time en Etapa 2 previa validación
  endTime        String   // "18:00"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now()) // agregado en Stage 1
  updatedAt      DateTime @updatedAt      // agregado en Stage 1

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  // A pro can have one weekly entry per (branch, day). Phase 2 dropped the
  // tenant-scoped unique key in favour of this branch-scoped one.
  @@unique([branchId, professionalId, dayOfWeek])
  @@index([tenantId, professionalId])
  @@index([branchId])
  @@map("work_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHEDULE EXCEPTION (bloqueos, vacaciones, feriados)
//
// Stage 1: se agrega tenantId para queries eficientes y futura RLS.
// ─────────────────────────────────────────────────────────────────────────────

model ScheduleException {
  id             String        @id @default(cuid())
  tenantId       String        // agregado en Stage 1
  professionalId String
  date           DateTime      @db.Date
  type           ExceptionType
  startTime      String?       // null = todo el día bloqueado
  endTime        String?
  reason         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt // agregado en Stage 1

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([tenantId, professionalId, date])
  @@map("schedule_exceptions")
}

enum ExceptionType {
  BLOCK
  VACATION
  HOLIDAY
  CUSTOM_HOURS
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT (turno)
// ─────────────────────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(cuid())
  tenantId           String
  /// Stage 1 (branches) — phase 2: NOT NULL. Every appointment is anchored
  /// to exactly one sucursal; the slot engine and create/reschedule writes
  /// guarantee a value at insert time.
  branchId           String
  clientId           String?           // FK → Client
  professionalId     String
  status             AppointmentStatus @default(PENDING)
  startAt            DateTime
  endAt              DateTime
  totalMinutes       Int
  totalPrice         Decimal           @db.Decimal(10, 2)
  currency           String            @default("ARS")
  notes              String?           // notas del cliente
  internalNotes      String?           // notas internas del negocio
  // datos de invitado
  guestName          String?
  guestEmail         String?
  guestPhone         String?
  // auditoría de cancelación / reprogramación
  cancelledAt        DateTime?
  cancelledBy        String?           // userId quien canceló
  cancellationReason String?
  rescheduledFromId  String?           // id del appointment original
  confirmedAt        DateTime?
  completedAt        DateTime?
  // ── Stage 1 ──────────────────────────────────────────────────────────────
  version            Int               @default(1) // optimistic locking ORM
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  client               Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  professional         Professional         @relation(fields: [professionalId], references: [id])
  items                AppointmentItem[]
  appointmentResources AppointmentResource[] // agregado en Stage 1

  @@index([tenantId, startAt])
  @@index([tenantId, status, startAt]) // agregado en Stage 1 — dashboard queries
  @@index([professionalId, startAt])
  @@index([branchId, startAt])         // agregado en Stage 1 (branches) — agenda por sede
  @@index([clientId])
  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  RESCHEDULED
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT ITEM (servicios dentro de un turno — soporta múltiples)
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentItem {
  id              String  @id @default(cuid())
  appointmentId   String
  serviceId       String
  serviceName     String  // snapshot en el momento de la reserva
  durationMinutes Int
  price           Decimal @db.Decimal(10, 2) // → renombrar a unitPrice en Etapa 2
  order           Int     @default(0)

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])

  @@index([appointmentId])
  @@map("appointment_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// RESOURCE (recursos físicos: cabinas, sillas, salas, equipos)
//
// Stage 1: se agregan description, capacity, createdAt, updatedAt
//          y la relación appointmentResources.
// ─────────────────────────────────────────────────────────────────────────────

model Resource {
  id          String   @id @default(cuid())
  tenantId    String
  /// Stage 1 (branches) — phase 2: NOT NULL. Resources (cabinas, sillas,
  /// salas, equipos) are physical assets and always live at exactly one
  /// sucursal.
  branchId    String
  name        String
  type        String   // → migrar a resourceTypeId FK en Etapa 2
  description String?  // agregado en Stage 1
  capacity    Int      @default(1) // agregado en Stage 1
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) // agregado en Stage 1
  updatedAt   DateTime @updatedAt      // agregado en Stage 1

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch               Branch               @relation(fields: [branchId], references: [id], onDelete: Restrict)
  services             ServiceResource[]
  appointmentResources AppointmentResource[] // agregado en Stage 1

  @@index([branchId])
  @@map("resources")
}

model ServiceResource {
  serviceId  String
  resourceId String

  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([serviceId, resourceId])
  @@map("service_resources")
}

// ─────────────────────────────────────────────────────────────────────────────
// CLIENT (CRM por tenant)
//
// Stage 1: tabla creada. appointments.clientId todavía apunta a User.
//          La migración de appointments.clientId → Client ocurre en Etapa 2.
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  // null = guest que no tiene cuenta en el sistema
  firstName String
  lastName  String
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  workOrders   WorkOrder[]

  // PostgreSQL trata NULL como distinto de NULL en constraints UNIQUE,
  // por lo tanto múltiples guests (userId=NULL) son permitidos en el mismo tenant.
  // La constraint sólo previene que el mismo usuario registrado aparezca dos veces.
  @@unique([tenantId, userId])
  @@index([tenantId, email])
  @@map("clients")
}

// ─────────────────────────────────────────────────────────────────────────────
// APPOINTMENT RESOURCE (recursos físicos asignados a un turno)
//
// Stage 1: tabla nueva. Habilita tracking de qué recurso fue usado
//          por qué turno, y permite detectar doble reserva de recursos.
// ─────────────────────────────────────────────────────────────────────────────

model AppointmentResource {
  id               String   @id @default(cuid())
  appointmentId    String
  resourceId       String
  resourceName     String   // snapshot del nombre al momento de la asignación
  assignedAt       DateTime @default(now())
  assignedByUserId String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  resource    Resource    @relation(fields: [resourceId], references: [id])
  assignedBy  User?       @relation(fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([appointmentId, resourceId])
  @@index([resourceId, assignedAt]) // para verificar disponibilidad de recurso
  @@map("appointment_resources")
}

// ─────────────────────────────────────────────────────────────────────────────
// SCHEDULE RULE (configuración global del negocio)
// ─────────────────────────────────────────────────────────────────────────────

model ScheduleRule {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  slotDurationMinutes Int     @default(15)
  bookingWindowDays   Int     @default(30)
  minAdvanceMinutes   Int     @default(60)
  cancelHoursMin      Int     @default(24)
  rescheduleHoursMin  Int     @default(24)
  allowGuestBooking   Boolean @default(true)
  requireConfirmation Boolean @default(false)
  autoConfirm         Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("schedule_rules")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String
  payload   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS — Work Orders (Phase 1)
// ─────────────────────────────────────────────────────────────────────────────

enum DurationUnit {
  MINUTES
  HOURS
  WORKDAYS
}

enum WorkOrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WorkSlotStatus {
  SCHEDULED
  COMPLETED
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK ORDER (orden de trabajo — servicios multi-profesional / multi-día)
//
// Phase 1: admin-only creation, manual staff assignment, no guest booking.
// Coexists with Appointment: simple services use Appointment, complex
// services (minProfessionals > 1 or allowsMultiDay) use WorkOrder.
// ─────────────────────────────────────────────────────────────────────────────

model WorkOrder {
  id                String           @id @default(cuid())
  tenantId          String
  branchId          String
  serviceId         String
  clientId          String?

  status            WorkOrderStatus  @default(PENDING)
  scheduledStartAt  DateTime         // planned start (UTC)
  scheduledEndAt    DateTime         // estimated end (UTC)
  totalPrice        Decimal          @default(0) @db.Decimal(10, 2)
  estimatedMinutes  Int              // total effective duration in minutes
  notes             String?

  confirmedAt       DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  service   Service  @relation(fields: [serviceId], references: [id])
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workSlots WorkSlot[]

  @@index([tenantId, status])
  @@index([tenantId, scheduledStartAt])
  @@index([tenantId, branchId, scheduledStartAt])
  @@map("work_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORK SLOT (tramo de trabajo dentro de una WorkOrder)
//
// Each slot represents one day (or partial day) of work. A 2-workday service
// generates 2 WorkSlots. The admin assigns professionals to each slot.
// ─────────────────────────────────────────────────────────────────────────────

model WorkSlot {
  id              String           @id @default(cuid())
  workOrderId     String
  date            DateTime         @db.Date       // calendar date (local)
  startTime       String           // "09:00" — local time
  endTime         String           // "17:00" — local time
  startAt         DateTime         // absolute UTC start
  endAt           DateTime         // absolute UTC end
  status          WorkSlotStatus   @default(SCHEDULED)
  notes           String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  workOrder   WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assignments StaffAssignment[]

  @@index([workOrderId])
  @@index([startAt, endAt])
  @@map("work_slots")
}

// ─────────────────────────────────────────────────────────────────────────────
// STAFF ASSIGNMENT (profesional asignado a un WorkSlot)
//
// Phase 1: simple — an assignment exists or it doesn't. No role, no status,
// no removal tracking. The admin assigns/unassigns freely as long as the
// slot maintains minProfessionals. Phase 2 adds LEAD/COLLABORATOR roles.
// ─────────────────────────────────────────────────────────────────────────────

model StaffAssignment {
  id               String       @id @default(cuid())
  workSlotId       String
  professionalId   String

  createdAt        DateTime     @default(now())

  workSlot     WorkSlot     @relation(fields: [workSlotId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id])

  @@unique([workSlotId, professionalId])
  @@index([professionalId])
  @@map("staff_assignments")
}
