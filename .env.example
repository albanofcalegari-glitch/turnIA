# Database
DATABASE_URL="postgresql://postgres@localhost:5432/turnia"

# JWT
JWT_SECRET="turnia-dev-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# App
NODE_ENV="development"
API_PORT=4000
WEB_PORT=3000
WEB_URL="http://localhost:3000"
API_URL="http://localhost:4000"

# Mercado Pago (Suscripciones)
# Test credentials: https://www.mercadopago.com.ar/developers/panel/app/<app>/credentials
MP_ACCESS_TOKEN="TEST-..."
MP_PUBLIC_KEY="TEST-..."
# HMAC secret from MP dashboard → Webhooks → "Clave secreta"
MP_WEBHOOK_SECRET=""
# Plan id — obtained from running: node scripts/mp-create-plan.mjs
MP_PLAN_ID=""
# Public HTTPS callback URL after checkout. MP rejects http/localhost, so in
# local dev point this at your ngrok tunnel or the prod dashboard URL.
MP_BACK_URL="https://turnit.com.ar/dashboard/suscripcion/callback"

# Resend (transactional email — sign up at https://resend.com)
RESEND_API_KEY=""
# Sender. En dev podés usar "turnIT <onboarding@resend.dev>". En prod conviene
# validar tu dominio en Resend y usar "turnIT <noreply@turnit.com.ar>".
MAIL_FROM="turnIT <onboarding@resend.dev>"
